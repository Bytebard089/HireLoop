# Required — use Groq key (gsk_...) for free LLM, or OpenAI key (sk-...)
OPENAI_API_KEY=gsk-...

# Optional Groq model (only used when API key starts with gsk_)
GROQ_MODEL=llama3-8b-8192

# Optional — defaults to SQLite for local dev
DATABASE_URL=sqlite:///./hireloop.db

# Optional — defaults shown
MODEL_PATH=./ml/model.pkl
SEED_DATASET_PATH=./ml/seed_dataset.csv
CHROMA_PERSIST_PATH=./chroma_store
MODELS_DIR=./ml/models

# RAG — set to 1 to enable embedding-based retrieval (requires sentence-transformers)
RAG_ENABLED=0

# For CORS — set to your Vercel URL in production
FRONTEND_URL=http://localhost:5173

FLASK_ENV=development
